# Build-time public config (baked into the static app — NOT secret).
PUBLIC_GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxx
PUBLIC_OAUTH_REDIRECT=https://your-app.pages.dev/auth/callback
PUBLIC_REPO_OWNER=your-github-username
PUBLIC_REPO=your-journal-repo
PUBLIC_BRANCH=main

# Server-only secret — set in Cloudflare Pages → Settings → Variables & Secrets,
# NOT committed and NOT prefixed PUBLIC_. Used only by the token-exchange Function.
# GITHUB_CLIENT_SECRET=...
