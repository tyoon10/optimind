# Required
ANTHROPIC_API_KEY=sk-ant-...
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# Required in production: absolute path to your optimind-journal checkout.
# Contains user_profile.json, state.json, and journal/YYYY-MM-DD.md files.
# When unset (dev only), falls back to <optimind-sdk>/data/ with a warning.
OPTIMIND_JOURNAL_PATH=/absolute/path/to/optimind-journal

# Optional: Git-synced journal (omit for local-only mode)
GITHUB_PAT=ghp_...
JOURNAL_REPO_URL=https://github.com/your-user/your-journal-repo.git
